{
  "name": "earthsci-toolkit",
  "version": "0.8.0",
  "type": "module",
  "description": "TypeScript types and utilities for EarthSciML Serialization Format",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "npm run build:rollup && npm run build:copy-types && npm run build:pkg-markers",
    "build:clean": "rm -rf dist/esm dist/cjs dist/index.d.ts",
    "build:rollup": "rollup -c",
    "build:copy-types": "mkdir -p dist/esm dist/cjs && cp dist/index.d.ts dist/esm/index.d.ts && cp dist/index.d.ts dist/cjs/index.d.ts",
    "build:pkg-markers": "node -e \"require('fs').writeFileSync('dist/cjs/package.json', JSON.stringify({type:'commonjs'})+'\\n'); require('fs').writeFileSync('dist/esm/package.json', JSON.stringify({type:'module'})+'\\n')\"",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "npm run test -- --run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "format": "prettier --write src *.json *.js *.ts",
    "format:check": "prettier --check src *.json *.js *.ts",
    "generate-schema": "node scripts/generate-embedded-schema.mjs",
    "generate-types": "json2ts -i ../../esm-schema.json -o src/generated.ts",
    "prepublishOnly": "npm run build",
    "publish:dry-run": "npm publish --dry-run",
    "publish:beta": "npm publish --tag beta",
    "publish:release": "npm publish"
  },
  "files": [
    "dist",
    "schema",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "earth-science",
    "scientific-modeling",
    "serialization",
    "typescript",
    "modeling",
    "chemistry",
    "atmospheric-science",
    "json-schema",
    "expressions",
    "mathematical-modeling"
  ],
  "author": "EarthSciML Authors and Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EarthSciML/EarthSciSerialization.git",
    "directory": "packages/earthsci-toolkit"
  },
  "bugs": {
    "url": "https://github.com/EarthSciML/EarthSciSerialization/issues"
  },
  "homepage": "https://github.com/EarthSciML/EarthSciSerialization#readme",
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^20.0.0",
    "json-schema-to-typescript": "^13.0.0",
    "rollup": "^4.57.1",
    "rollup-plugin-dts": "^6.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "overrides": {
    "undici": "^7.28.0"
  }
}
