{
  "esm": "0.5.0",
  "kind": "grid_discretization_descriptor",
  "metadata": {
    "name": "cartesian_1d_n16_periodic",
    "description": "Uniform 1-D domain, N=16 cells, periodic BCs. Finer grid than the N=8 variant; used in multi-entry grid_refs sweep tests."
  },
  "grids": {
    "gx": {
      "family": "cartesian",
      "dimensions": [
        {"name": "i", "size": 16, "periodic": true, "spacing": "uniform"}
      ]
    }
  },
  "discretizations": {
    "centered_grad": {
      "applies_to": {"op": "grad", "args": ["$u"], "dim": "$x"},
      "grid_family": "cartesian",
      "combine": "+",
      "stencil": [
        {
          "selector": {"kind": "cartesian", "axis": "$x", "offset": -1},
          "coeff": {"op": "/", "args": [-1, {"op": "*", "args": [2, "dx"]}]}
        },
        {
          "selector": {"kind": "cartesian", "axis": "$x", "offset": 1},
          "coeff": {"op": "/", "args": [1, {"op": "*", "args": [2, "dx"]}]}
        }
      ]
    }
  }
}
