    "RothermelFireSpread": {
      "variables": { "sigma": { "type": "parameter", "units": "1/m", "default": 0.0 } },
      "equations": []
    }
  },
  "coupling": [
    {
      "type": "coupling_import",
      "ref": "./rothermel_fuel.esm",
      "bind": { "Fuel": "FuelModelLookup" }
