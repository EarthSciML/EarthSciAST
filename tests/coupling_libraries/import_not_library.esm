{
  "esm": "0.8.0",
  "metadata": {
    "name": "import_not_library",
    "description": "INVALID import: the coupling_import ref targets plain_model.esm, an ordinary model document with no top-level coupling_roles - not a coupling-library file (esm-spec 10.9/10.11). Expected: coupling_import_not_library."
  },
  "models": {
    "FuelModelLookup": {
      "variables": { "sigma": { "type": "parameter", "units": "1/m", "default": 1500.0 } },
      "equations": []
    },
    "RothermelFireSpread": {
      "variables": { "sigma": { "type": "parameter", "units": "1/m", "default": 0.0 } },
      "equations": []
    }
  },
  "coupling": [
    {
      "type": "coupling_import",
      "ref": "./plain_model.esm",
      "bind": { "Fuel": "FuelModelLookup", "Spread": "RothermelFireSpread" }
    }
  ]
}
