{
  "esm": "0.8.0",
  "metadata": {
    "name": "import_unknown_role",
    "description": "INVALID import: the bind carries key 'Ghost', which rothermel_fuel.esm does not declare as a role (catches typos and stale binds; esm-spec 10.10.1). Expected: coupling_import_unknown_role."
  },
  "models": {
    "FuelModelLookup": {
      "variables": { "sigma": { "type": "parameter", "units": "1/m", "default": 1500.0 } },
      "equations": []
    },
    "RothermelFireSpread": {
      "variables": { "sigma": { "type": "parameter", "units": "1/m", "default": 0.0 } },
      "equations": []
    }
  },
  "coupling": [
    {
      "type": "coupling_import",
      "ref": "./rothermel_fuel.esm",
      "bind": { "Fuel": "FuelModelLookup", "Spread": "RothermelFireSpread", "Ghost": "FuelModelLookup" }
    }
  ]
}
