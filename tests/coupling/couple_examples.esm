{
  "esm": "0.2.0",
  "metadata": {
    "name": "CoupleExamples",
    "description": "Test fixtures for couple coupling type with connector equations\nMigrated from ESM v0.1.0 to v0.2.0 via esm-migrate.",
    "authors": [
      "Claude Sonnet 4"
    ],
    "created": "2026-02-16T00:00:00Z",
    "tags": [
      "migrated_from_v01"
    ]
  },
  "models": {
    "FluidFlow": {
      "reference": {
        "notes": "1D fluid flow system"
      },
      "variables": {
        "velocity": {
          "type": "state",
          "units": "m/s",
          "default": 1.0,
          "description": "Flow velocity"
        },
        "pressure": {
          "type": "state",
          "units": "Pa",
          "default": 101325.0,
          "description": "Fluid pressure"
        },
        "density": {
          "units": "kg/m^3",
          "default": 1000.0,
          "description": "Fluid density",
          "type": "parameter"
        },
        "viscosity": {
          "units": "Pa·s",
          "default": 0.001,
          "description": "Dynamic viscosity",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "velocity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "/",
                "args": [
                  {
                    "op": "grad",
                    "args": [
                      "pressure"
                    ],
                    "dim": "x"
                  },
                  "density"
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      "viscosity",
                      "density"
                    ]
                  },
                  {
                    "op": "laplacian",
                    "args": [
                      "velocity"
                    ]
                  }
                ]
              }
            ]
          }
        }
      ]
    },
    "HeatTransfer": {
      "reference": {
        "notes": "1D heat conduction system"
      },
      "variables": {
        "temperature": {
          "type": "state",
          "units": "K",
          "default": 300.0,
          "description": "Temperature"
        },
        "thermal_diffusivity": {
          "units": "m^2/s",
          "default": 1e-07,
          "description": "Thermal diffusivity",
          "type": "parameter"
        },
        "convective_heat_flux": {
          "type": "parameter",
          "units": "K/s",
          "default": 0.0,
          "description": "Convective heating rate supplied by the FluidFlow<->HeatTransfer connector (additive). A coupling `to` target MUST be a DECLARED variable -- flattening (esm-spec 10.4/10.7) REPLACES it with a derived observed carrying the connector expression -- and this name was previously read by the temperature equation while being declared NOWHERE."
        },
        "viscous_heating": {
          "type": "parameter",
          "units": "K/s",
          "default": 0.0,
          "description": "Viscous-dissipation heating rate supplied by the connector (additive). Previously the connector wrote to this name and NOTHING read it -- a dead coupling edge; the temperature equation now consumes it."
        },
        "heat_capacity": {
          "units": "J/(kg·K)",
          "default": 4180.0,
          "description": "Specific heat capacity",
          "type": "parameter"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "temperature"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "thermal_diffusivity",
                  {
                    "op": "laplacian",
                    "args": [
                      "temperature"
                    ]
                  }
                ]
              },
              "convective_heat_flux",
              "viscous_heating"
            ]
          }
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "couple",
      "systems": [
        "FluidFlow",
        "HeatTransfer"
      ],
      "connector": {
        "equations": [
          {
            "from": "FluidFlow.velocity",
            "to": "HeatTransfer.convective_heat_flux",
            "transform": "additive",
            "expression": {
              "op": "*",
              "args": [
                "FluidFlow.velocity",
                {
                  "op": "grad",
                  "args": [
                    "HeatTransfer.temperature"
                  ],
                  "dim": "x"
                }
              ]
            }
          },
          {
            "from": "FluidFlow.velocity",
            "to": "HeatTransfer.viscous_heating",
            "transform": "additive",
            "expression": {
              "op": "/",
              "args": [
                {
                  "op": "*",
                  "args": [
                    "FluidFlow.viscosity",
                    {
                      "op": "^",
                      "args": [
                        {
                          "op": "grad",
                          "args": [
                            "FluidFlow.velocity"
                          ],
                          "dim": "x"
                        },
                        2
                      ]
                    }
                  ]
                },
                {
                  "op": "*",
                  "args": [
                    "FluidFlow.density",
                    "HeatTransfer.heat_capacity"
                  ]
                }
              ]
            }
          }
        ]
      }
    }
  ],
  "domain": {
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-01T01:00:00Z"
    },
    "element_type": "Float64"
  }
}
