{
  "esm": "0.8.0",
  "metadata": {
    "name": "template_import_rename_lib",
    "description": "Two-template library backing the esm-spec 9.7.7 rename/rebind invalid fixtures: two zero-parameter templates (area, perim) so a per-edge rename can collide, a metaparameter-sized index set, and a free weight name w in area so a rebind has a free name to address. Also a FIRST-CLASS standalone document (esm-spec 9.7.1): a top-level `expression_templates` registry satisfies the schema's top-level anyOf on its own, so a model-less library file is ADMITTED, not merely tolerated. Per 9.6.4 rule 5 the registry and `metaparameters` survive parse -> emit verbatim and this file MUST round-trip to ITSELF."
  },
  "metaparameters": {
    "M": {
      "type": "integer",
      "default": 3,
      "description": "edge count"
    }
  },
  "index_sets": {
    "edges": {
      "kind": "interval",
      "size": "M"
    }
  },
  "expression_templates": {
    "area": {
      "params": [],
      "body": {
        "op": "*",
        "args": [
          "w",
          "M"
        ]
      }
    },
    "perim": {
      "params": [],
      "body": {
        "op": "*",
        "args": [
          2,
          "M"
        ]
      }
    }
  }
}
