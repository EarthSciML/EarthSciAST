{
  "esm": "0.1.0",
  "metadata": {
    "name": "ScopedReferencesNestedTest",
    "description": "Test fixture for deeply nested scoped reference notation (A.B.C.D.variable). Every equation is dimensionally coherent: each coefficient is a NAMED PARAMETER carrying the units that make its term land on the left-hand side dimension, so a dimensional checker can prove the file sound rather than having to suppress it.",
    "authors": [
      "Claude Sonnet 4"
    ],
    "created": "2026-02-16T00:00:00Z",
    "license": "CC0",
    "tags": [
      "test",
      "scoped_references",
      "hierarchical",
      "nesting"
    ]
  },
  "models": {
    "EarthSystem": {
      "reference": {
        "notes": "Top-level Earth system model"
      },
      "variables": {
        "global_forcing": {
          "type": "parameter",
          "units": "W/m^2",
          "default": 1361.0,
          "description": "Solar constant"
        },
        "system_energy": {
          "type": "state",
          "units": "J",
          "default": 0.0,
          "description": "Total system energy"
        },
        "earth_area": {
          "type": "parameter",
          "units": "m^2",
          "default": 510000000000000.0,
          "description": "Earth surface area — converts the W/m^2 forcing into a system-wide power (W)"
        },
        "stefan_boltzmann": {
          "type": "parameter",
          "units": "W/(m^2*K^4)",
          "default": 5.67e-08,
          "description": "Stefan-Boltzmann constant — carries the units that make sigma*T^4 a flux density"
        }
      },
      "subsystems": {
        "Atmosphere": {
          "reference": {
            "notes": "Atmospheric component"
          },
          "variables": {
            "atm_temperature": {
              "type": "state",
              "units": "K",
              "default": 288.0,
              "description": "Mean atmospheric temperature"
            },
            "atm_pressure": {
              "type": "parameter",
              "units": "Pa",
              "default": 101325.0,
              "description": "Surface pressure — a parameter; the only integrated unknown in this subsystem is atm_temperature"
            },
            "atm_heat_capacity": {
              "type": "parameter",
              "units": "J/(m^2*K)",
              "default": 1000000.0,
              "description": "Column heat capacity — turns the W/m^2 forcing into a temperature tendency (K/s)"
            },
            "atm_ocean_exchange": {
              "type": "parameter",
              "units": "1/s",
              "default": 0.0002,
              "description": "Air-sea temperature relaxation rate"
            },
            "latent_heating_coeff": {
              "type": "parameter",
              "units": "K*m^3/(kg*s)",
              "default": 0.1,
              "description": "Latent-heating coefficient per unit water-vapour density"
            }
          },
          "subsystems": {
            "Troposphere": {
              "reference": {
                "notes": "Lower atmospheric layer"
              },
              "variables": {
                "trop_water_vapor": {
                  "type": "state",
                  "units": "kg/m^3",
                  "default": 0.01,
                  "description": "Water vapor density"
                },
                "convection_rate": {
                  "type": "parameter",
                  "units": "1/s",
                  "default": 0.0001,
                  "description": "Convection rate"
                }
              },
              "subsystems": {
                "BoundaryLayer": {
                  "reference": {
                    "notes": "Atmospheric boundary layer"
                  },
                  "variables": {
                    "boundary_height": {
                      "type": "state",
                      "units": "m",
                      "default": 1000.0,
                      "description": "Boundary layer height"
                    },
                    "friction_velocity": {
                      "type": "parameter",
                      "units": "m/s",
                      "default": 0.1,
                      "description": "Surface friction velocity"
                    },
                    "entrainment_timescale": {
                      "type": "parameter",
                      "units": "s",
                      "default": 0.1,
                      "description": "Convective entrainment timescale — makes friction_velocity*timescale*convection_rate a velocity"
                    },
                    "bl_relax_rate": {
                      "type": "parameter",
                      "units": "1/s",
                      "default": 0.001,
                      "description": "Boundary-layer height relaxation rate toward the ocean mixed-layer depth"
                    }
                  },
                  "equations": [
                    {
                      "_comment": "d(boundary_height)/dt [m/s] = u*·(tau·convection_rate) - relax*(h - mixing_depth). Both terms are m/s.",
                      "lhs": {
                        "op": "D",
                        "args": [
                          "boundary_height"
                        ],
                        "wrt": "t"
                      },
                      "rhs": {
                        "op": "+",
                        "args": [
                          {
                            "op": "*",
                            "args": [
                              "EarthSystem.Atmosphere.Troposphere.BoundaryLayer.friction_velocity",
                              {
                                "op": "*",
                                "args": [
                                  "entrainment_timescale",
                                  "EarthSystem.Atmosphere.Troposphere.convection_rate"
                                ]
                              }
                            ]
                          },
                          {
                            "op": "*",
                            "args": [
                              {
                                "op": "-",
                                "args": [
                                  "bl_relax_rate"
                                ]
                              },
                              {
                                "op": "-",
                                "args": [
                                  "boundary_height",
                                  "EarthSystem.Ocean.MixedLayer.mixing_depth"
                                ]
                              }
                            ]
                          }
                        ]
                      }
                    }
                  ]
                }
              },
              "equations": [
                {
                  "_comment": "d(trop_water_vapor)/dt [kg/(m^3*s)] = evaporation_flux/boundary_height - convection_rate*q.",
                  "lhs": {
                    "op": "D",
                    "args": [
                      "trop_water_vapor"
                    ],
                    "wrt": "t"
                  },
                  "rhs": {
                    "op": "+",
                    "args": [
                      {
                        "op": "/",
                        "args": [
                          "EarthSystem.Ocean.Surface.evaporation_rate",
                          "EarthSystem.Atmosphere.Troposphere.BoundaryLayer.boundary_height"
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          {
                            "op": "-",
                            "args": [
                              "EarthSystem.Atmosphere.Troposphere.convection_rate"
                            ]
                          },
                          "trop_water_vapor"
                        ]
                      }
                    ]
                  }
                }
              ]
            }
          },
          "equations": [
            {
              "_comment": "d(atm_temperature)/dt [K/s] = forcing/heat_capacity - exchange*(T_atm - sst) + latent*q. Every term is K/s.",
              "lhs": {
                "op": "D",
                "args": [
                  "atm_temperature"
                ],
                "wrt": "t"
              },
              "rhs": {
                "op": "+",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      "EarthSystem.global_forcing",
                      "atm_heat_capacity"
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          "atm_ocean_exchange"
                        ]
                      },
                      {
                        "op": "-",
                        "args": [
                          "atm_temperature",
                          "EarthSystem.Ocean.Surface.sst"
                        ]
                      }
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "latent_heating_coeff",
                      "EarthSystem.Atmosphere.Troposphere.trop_water_vapor"
                    ]
                  }
                ]
              }
            }
          ]
        },
        "Ocean": {
          "reference": {
            "notes": "Oceanic component"
          },
          "variables": {
            "ocean_heat_content": {
              "type": "state",
              "units": "J",
              "default": 1e+21,
              "description": "Ocean heat content"
            },
            "mixed_layer_heat_coeff": {
              "type": "parameter",
              "units": "J/(K*m*s)",
              "default": 4180000.0,
              "description": "Mixed-layer heat-content tendency coefficient (per unit temperature and depth)"
            },
            "deep_heat_coeff": {
              "type": "parameter",
              "units": "J/(K*m*s)",
              "default": 1000000.0,
              "description": "Deep-layer heat-content tendency coefficient (per unit temperature and depth)"
            }
          },
          "subsystems": {
            "Surface": {
              "reference": {
                "notes": "Ocean surface layer"
              },
              "variables": {
                "sst": {
                  "type": "state",
                  "units": "K",
                  "default": 285.0,
                  "description": "Sea surface temperature"
                },
                "evaporation_rate": {
                  "type": "parameter",
                  "units": "kg/(m^2*s)",
                  "default": 1e-06,
                  "description": "Evaporation rate"
                },
                "ocean_heat_capacity": {
                  "type": "parameter",
                  "units": "J/(m^2*K)",
                  "default": 2000000.0,
                  "description": "Mixed-layer heat capacity — turns the W/m^2 forcing into a temperature tendency"
                },
                "air_sea_exchange": {
                  "type": "parameter",
                  "units": "1/s",
                  "default": 0.0001,
                  "description": "Air-sea temperature exchange rate"
                }
              },
              "equations": [
                {
                  "_comment": "d(sst)/dt [K/s] = forcing/heat_capacity + exchange*(T_atm - sst) - w_up*stratification. w_up [m/s] * dT/dz [K/m] = K/s.",
                  "lhs": {
                    "op": "D",
                    "args": [
                      "sst"
                    ],
                    "wrt": "t"
                  },
                  "rhs": {
                    "op": "+",
                    "args": [
                      {
                        "op": "/",
                        "args": [
                          "EarthSystem.global_forcing",
                          "ocean_heat_capacity"
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          "air_sea_exchange",
                          {
                            "op": "-",
                            "args": [
                              "EarthSystem.Atmosphere.atm_temperature",
                              "sst"
                            ]
                          }
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          {
                            "op": "-",
                            "args": [
                              "EarthSystem.Ocean.MixedLayer.upwelling_velocity"
                            ]
                          },
                          "EarthSystem.Ocean.MixedLayer.Thermocline.stratification"
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            "MixedLayer": {
              "reference": {
                "notes": "Ocean mixed layer"
              },
              "variables": {
                "mixing_depth": {
                  "type": "state",
                  "units": "m",
                  "default": 100.0,
                  "description": "Mixed layer depth"
                },
                "upwelling_velocity": {
                  "type": "parameter",
                  "units": "m/s",
                  "default": 1e-05,
                  "description": "Upwelling velocity"
                },
                "mld_relax_rate": {
                  "type": "parameter",
                  "units": "1/s",
                  "default": 0.001,
                  "description": "Mixed-layer-depth relaxation rate toward its reference depth"
                },
                "mld_reference": {
                  "type": "parameter",
                  "units": "m",
                  "default": 50.0,
                  "description": "Reference mixed-layer depth"
                }
              },
              "subsystems": {
                "Thermocline": {
                  "reference": {
                    "notes": "Ocean thermocline"
                  },
                  "variables": {
                    "stratification": {
                      "type": "state",
                      "units": "K/m",
                      "default": 0.01,
                      "description": "Temperature gradient"
                    },
                    "buoyancy_frequency": {
                      "type": "parameter",
                      "units": "1/s",
                      "default": 0.001,
                      "description": "Brunt-Väisälä frequency"
                    },
                    "stratification_decay": {
                      "type": "parameter",
                      "units": "1/s",
                      "default": 0.001,
                      "description": "Stratification decay rate"
                    }
                  },
                  "equations": [
                    {
                      "_comment": "d(stratification)/dt [K/(m*s)] = N*(dT/h) - decay*stratification.",
                      "lhs": {
                        "op": "D",
                        "args": [
                          "stratification"
                        ],
                        "wrt": "t"
                      },
                      "rhs": {
                        "op": "+",
                        "args": [
                          {
                            "op": "*",
                            "args": [
                              "EarthSystem.Ocean.MixedLayer.Thermocline.buoyancy_frequency",
                              {
                                "op": "/",
                                "args": [
                                  {
                                    "op": "-",
                                    "args": [
                                      "EarthSystem.Ocean.Surface.sst",
                                      "EarthSystem.Ocean.DeepOcean.deep_temperature"
                                    ]
                                  },
                                  "EarthSystem.Ocean.MixedLayer.mixing_depth"
                                ]
                              }
                            ]
                          },
                          {
                            "op": "*",
                            "args": [
                              {
                                "op": "-",
                                "args": [
                                  "stratification_decay"
                                ]
                              },
                              "stratification"
                            ]
                          }
                        ]
                      }
                    }
                  ]
                }
              },
              "equations": [
                {
                  "_comment": "d(mixing_depth)/dt [m/s] = 0.01*sqrt(u*·N·h) - relax*(h - h_ref). sqrt((m/s)(1/s)(m)) = sqrt(m^2/s^2) = m/s.",
                  "lhs": {
                    "op": "D",
                    "args": [
                      "mixing_depth"
                    ],
                    "wrt": "t"
                  },
                  "rhs": {
                    "op": "+",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          0.01,
                          {
                            "op": "sqrt",
                            "args": [
                              {
                                "op": "*",
                                "args": [
                                  "EarthSystem.Atmosphere.Troposphere.BoundaryLayer.friction_velocity",
                                  "EarthSystem.Ocean.MixedLayer.Thermocline.buoyancy_frequency",
                                  "mixing_depth"
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          {
                            "op": "-",
                            "args": [
                              "mld_relax_rate"
                            ]
                          },
                          {
                            "op": "-",
                            "args": [
                              "mixing_depth",
                              "mld_reference"
                            ]
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            },
            "DeepOcean": {
              "reference": {
                "notes": "Deep ocean layer"
              },
              "variables": {
                "deep_temperature": {
                  "type": "state",
                  "units": "K",
                  "default": 278.0,
                  "description": "Deep ocean temperature"
                },
                "deep_heat_capacity": {
                  "type": "parameter",
                  "units": "J/(m^2*K)",
                  "default": 100000000.0,
                  "description": "Deep-ocean heat capacity"
                },
                "deep_layer_depth": {
                  "type": "parameter",
                  "units": "m",
                  "default": 1000.0,
                  "description": "Deep-layer thickness — the depth scale of the upwelling temperature gradient"
                }
              },
              "equations": [
                {
                  "_comment": "d(deep_temperature)/dt [K/s] = forcing/heat_capacity + w_up*(dT/depth).",
                  "lhs": {
                    "op": "D",
                    "args": [
                      "deep_temperature"
                    ],
                    "wrt": "t"
                  },
                  "rhs": {
                    "op": "+",
                    "args": [
                      {
                        "op": "/",
                        "args": [
                          "EarthSystem.global_forcing",
                          "deep_heat_capacity"
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          "EarthSystem.Ocean.MixedLayer.upwelling_velocity",
                          {
                            "op": "/",
                            "args": [
                              {
                                "op": "-",
                                "args": [
                                  "EarthSystem.Ocean.Surface.sst",
                                  "deep_temperature"
                                ]
                              },
                              "EarthSystem.Ocean.DeepOcean.deep_layer_depth"
                            ]
                          }
                        ]
                      }
                    ]
                  }
                }
              ]
            }
          },
          "equations": [
            {
              "_comment": "d(ocean_heat_content)/dt [J/s] = c_ml*(sst*h) + c_deep*(T_deep*depth). Both terms are watts.",
              "lhs": {
                "op": "D",
                "args": [
                  "ocean_heat_content"
                ],
                "wrt": "t"
              },
              "rhs": {
                "op": "+",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      "mixed_layer_heat_coeff",
                      {
                        "op": "*",
                        "args": [
                          "EarthSystem.Ocean.Surface.sst",
                          "EarthSystem.Ocean.MixedLayer.mixing_depth"
                        ]
                      }
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "deep_heat_coeff",
                      {
                        "op": "*",
                        "args": [
                          "EarthSystem.Ocean.DeepOcean.deep_temperature",
                          "EarthSystem.Ocean.DeepOcean.deep_layer_depth"
                        ]
                      }
                    ]
                  }
                ]
              }
            }
          ]
        }
      },
      "equations": [
        {
          "_comment": "d(system_energy)/dt [W] = area*forcing - area*sigma*T^4 + 0.1*d(ocean_heat_content)/dt. Every term is a power.",
          "lhs": {
            "op": "D",
            "args": [
              "system_energy"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "earth_area",
                  "EarthSystem.global_forcing"
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "earth_area"
                    ]
                  },
                  {
                    "op": "*",
                    "args": [
                      "stefan_boltzmann",
                      {
                        "op": "^",
                        "args": [
                          "EarthSystem.Atmosphere.atm_temperature",
                          4
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  0.1,
                  {
                    "op": "D",
                    "args": [
                      "EarthSystem.Ocean.ocean_heat_content"
                    ],
                    "wrt": "t"
                  }
                ]
              }
            ]
          }
        }
      ]
    }
  },
  "domain": {
    "temporal": {
      "start": "2024-01-01T00:00:00Z",
      "end": "2024-01-02T00:00:00Z"
    },
    "element_type": "Float64"
  }
}
