{
  "esm": "0.6.0",
  "metadata": {
    "name": "min_sum_tropical",
    "description": "M1 cross-binding conformance fixture (RFC semiring-faq-unified-ir §5.1; bead ess-my4.1.5). The `min_sum` tropical semiring — (min,+inf;+,0) — used for shortest-path / least-cost contractions. State `dist[i]` reduces the additive body i+j with the min oplus over j drawn from the `paths` interval index set: dist[1]=min_{j=1..3}(1+j)=min(2,3,4)=2, dist[2]=min_{j=1..3}(2+j)=min(3,4,5)=3 at t=1. The oplus is min and the otimes is + (so the body is written as a sum), distinguishing this semiring from sum_product / max_product. The 0-bar identity for min_sum is +inf (an empty reduction), asserted at the per-binding unit level in every evaluator since +inf is not an integrable ODE rate; here a non-empty range exercises the min oplus end-to-end. Constant-RHS shape so Julia / Rust / Python agree to integration tolerance.",
    "authors": [
      "EarthSciSerialization/polecats/gastown.slit"
    ],
    "tags": [
      "aggregate",
      "semiring",
      "min_sum",
      "tropical",
      "index-set",
      "conformance",
      "ess-my4.1.5"
    ]
  },
  "index_sets": {
    "paths": {
      "kind": "interval",
      "size": 3
    }
  },
  "models": {
    "MinSumTropical": {
      "tolerance": {
        "rel": 1e-06,
        "abs": 1e-09
      },
      "variables": {
        "dist": {
          "type": "state",
          "shape": [
            "i"
          ]
        }
      },
      "equations": [
        {
          "_comment": "D(dist[i])/dt = min_{j in paths} (i+j). dist[1]=2, dist[2]=3 at t=1.",
          "lhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": [
              "i"
            ],
            "expr": {
              "op": "D",
              "args": [
                {
                  "op": "index",
                  "args": [
                    "dist",
                    "i"
                  ]
                }
              ],
              "wrt": "t"
            },
            "ranges": {
              "i": [
                1,
                2
              ]
            }
          },
          "rhs": {
            "op": "aggregate",
            "args": [],
            "output_idx": [
              "i"
            ],
            "semiring": "min_sum",
            "ranges": {
              "i": [
                1,
                2
              ],
              "j": {
                "from": "paths"
              }
            },
            "expr": {
              "op": "+",
              "args": [
                "i",
                "j"
              ]
            }
          }
        }
      ],
      "tests": [
        {
          "id": "min_sum_t1",
          "description": "Constant-RHS tropical contraction from zero ICs. dist[i]=min_{j=1..3}(i+j)=i+1 at t=1.",
          "initial_conditions": {
            "dist[1]": 0.0,
            "dist[2]": 0.0
          },
          "time_span": {
            "start": 0.0,
            "end": 1.0
          },
          "assertions": [
            {
              "variable": "dist[1]",
              "time": 1.0,
              "expected": 2.0
            },
            {
              "variable": "dist[2]",
              "time": 1.0,
              "expected": 3.0
            }
          ]
        }
      ]
    }
  }
}
