{
  "esm": "0.1.0",
  "metadata": {
    "name": "ExpressionGraphVariableDependencies",
    "description": "Complex variable-level dependency graph test case. Every expression is dimensionally coherent: the coefficients that used to be bare literals (-1000, 298.15, 8.314) are now named parameters carrying the units they always implicitly had, so a dimensional checker can prove the file sound. The k2*x^alpha*z^beta term deliberately keeps SYMBOLIC exponents — its dimension is genuinely undeterminable and must be reported as unknown, never assumed dimensionless.",
    "created": "2026-02-16T00:00:00Z"
  },
  "models": {
    "VariableDependencyModel": {
      "reference": {
        "notes": "Model demonstrating complex variable dependency chains"
      },
      "variables": {
        "x": {
          "type": "state",
          "units": "mol/L",
          "default": 1.0
        },
        "y": {
          "type": "state",
          "units": "mol/L",
          "default": 2.0
        },
        "z": {
          "type": "state",
          "units": "mol/L",
          "default": 0.5
        },
        "T": {
          "type": "parameter",
          "units": "K",
          "default": 298.15
        },
        "P": {
          "type": "parameter",
          "units": "atm",
          "default": 1.0
        },
        "k1": {
          "type": "parameter",
          "units": "L/mol/s",
          "default": 0.1
        },
        "k2": {
          "type": "parameter",
          "units": "L^2/mol^2/s",
          "default": 0.01
        },
        "alpha": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 0.5
        },
        "beta": {
          "type": "parameter",
          "units": "dimensionless",
          "default": 2.0
        },
        "T_act": {
          "type": "parameter",
          "units": "K",
          "default": 1000.0,
          "description": "Activation temperature — makes the Arrhenius exponent T_act/T dimensionless"
        },
        "k_p": {
          "type": "parameter",
          "units": "1/(atm*s)",
          "default": 0.05,
          "description": "Pressure-driven production coefficient — carries 1/(atm*s) so that k_p*P*z is a concentration rate"
        },
        "T_ref": {
          "type": "parameter",
          "units": "K",
          "default": 298.15,
          "description": "Reference temperature — the T_ref/T ratio is dimensionless"
        },
        "k_y": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.02,
          "description": "First-order loss rate constant for y"
        },
        "kappa": {
          "type": "parameter",
          "units": "mol/(L*K)",
          "default": 0.001,
          "description": "Concentration-per-kelvin scale — makes (kappa*T)^2 commensurate with x*y"
        },
        "P_ref": {
          "type": "parameter",
          "units": "atm",
          "default": 1.0,
          "description": "Reference pressure — the P/P_ref ratio is the dimensionless logarithm argument"
        },
        "k_z": {
          "type": "parameter",
          "units": "1/s",
          "default": 0.05,
          "description": "Rate constant for z"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "x"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "+",
            "args": [
              {
                "op": "*",
                "args": [
                  "k1",
                  "x",
                  "y"
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "exp",
                    "args": [
                      {
                        "op": "/",
                        "args": [
                          {
                            "op": "-",
                            "args": [
                              "T_act"
                            ]
                          },
                          "T"
                        ]
                      }
                    ]
                  },
                  "P",
                  "z",
                  "k_p"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "y"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              {
                "op": "*",
                "args": [
                  "k2",
                  {
                    "op": "^",
                    "args": [
                      "x",
                      "alpha"
                    ]
                  },
                  {
                    "op": "^",
                    "args": [
                      "z",
                      "beta"
                    ]
                  }
                ]
              },
              {
                "op": "*",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      "T_ref",
                      "T"
                    ]
                  },
                  "y",
                  "k_y"
                ]
              }
            ]
          }
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "z"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "*",
            "args": [
              {
                "op": "sqrt",
                "args": [
                  {
                    "op": "+",
                    "args": [
                      {
                        "op": "*",
                        "args": [
                          "x",
                          "y"
                        ]
                      },
                      {
                        "op": "^",
                        "args": [
                          {
                            "op": "*",
                            "args": [
                              "kappa",
                              "T"
                            ]
                          },
                          2
                        ]
                      }
                    ]
                  }
                ]
              },
              {
                "op": "log",
                "args": [
                  {
                    "op": "+",
                    "args": [
                      1.0,
                      {
                        "op": "*",
                        "args": [
                          {
                            "op": "/",
                            "args": [
                              "P",
                              "P_ref"
                            ]
                          },
                          "alpha",
                          "beta"
                        ]
                      }
                    ]
                  }
                ]
              },
              "k_z"
            ]
          }
        }
      ]
    }
  },
  "reaction_systems": {
    "ComplexKinetics": {
      "reference": {
        "notes": "Reaction system with interdependent rate expressions. Per esm-spec §7.4 each `rate` is the rate CONSTANT k — mass action supplies the substrate product v = k*prod(S_i^n_i) — so an order-2 reaction's rate carries conc^-1/time (L/(mol*s)), not conc/time."
      },
      "species": {
        "A": {
          "units": "mol/L"
        },
        "B": {
          "units": "mol/L"
        },
        "C": {
          "units": "mol/L"
        },
        "D": {
          "units": "mol/L"
        }
      },
      "parameters": {
        "k_forward": {
          "units": "L/mol/s",
          "default": 0.2
        },
        "k_reverse": {
          "units": "L/(mol*s)",
          "default": 0.05,
          "description": "Second-order reverse rate constant for C + D -> A + B"
        },
        "T_reaction": {
          "units": "K",
          "default": 300.0
        },
        "activation_energy": {
          "units": "kJ/mol",
          "default": 50.0
        },
        "R_gas": {
          "units": "kJ/(mol*K)",
          "default": 0.008314,
          "description": "Molar gas constant — makes the Arrhenius exponent Ea/(R*T) dimensionless"
        },
        "T_ref_reaction": {
          "units": "K",
          "default": 298.15,
          "description": "Reference temperature — the T_reaction/T_ref_reaction ratio is dimensionless"
        }
      },
      "reactions": [
        {
          "id": "R1",
          "rate": {
            "op": "*",
            "args": [
              "k_forward",
              {
                "op": "exp",
                "args": [
                  {
                    "op": "/",
                    "args": [
                      {
                        "op": "-",
                        "args": [
                          "activation_energy"
                        ]
                      },
                      {
                        "op": "*",
                        "args": [
                          "R_gas",
                          "T_reaction"
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          },
          "substrates": [
            {
              "species": "A",
              "stoichiometry": 1
            },
            {
              "species": "B",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "C",
              "stoichiometry": 1
            },
            {
              "species": "D",
              "stoichiometry": 1
            }
          ]
        },
        {
          "id": "R2",
          "rate": {
            "op": "*",
            "args": [
              "k_reverse",
              {
                "op": "^",
                "args": [
                  {
                    "op": "+",
                    "args": [
                      1.0,
                      {
                        "op": "/",
                        "args": [
                          "T_reaction",
                          "T_ref_reaction"
                        ]
                      }
                    ]
                  },
                  2
                ]
              }
            ]
          },
          "substrates": [
            {
              "species": "C",
              "stoichiometry": 1
            },
            {
              "species": "D",
              "stoichiometry": 1
            }
          ],
          "products": [
            {
              "species": "A",
              "stoichiometry": 1
            },
            {
              "species": "B",
              "stoichiometry": 1
            }
          ]
        }
      ]
    }
  },
  "coupling": [
    {
      "type": "variable_map",
      "from": "VariableDependencyModel.T",
      "to": "ComplexKinetics.T_reaction",
      "transform": "param_to_var"
    }
  ]
}
