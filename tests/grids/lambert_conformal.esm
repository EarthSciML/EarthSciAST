{
  "esm": "0.6.0",
  "metadata": {
    "name": "LambertConformalGridFixture",
    "description": "Conformance fixture for the §6 Grid `crs` descriptor (RFC pure-io-data-loaders §4.2). A projected native grid: topologically cartesian, with crs.projection=lambert_conformal using WRF parameters on a spherical datum. Exercises crs round-trip and asserts that a projected native grid (WRF LCC params) validates while remaining orthogonal to the topological family (ess-v9a.2).",
    "authors": ["ESM Test Suite"],
    "created": "2026-06-25T00:00:00Z",
    "tags": ["grids", "cartesian", "crs", "lambert_conformal", "conformance"]
  },
  "models": {
    "AtmoBox": {
      "reference": {"notes": "Placeholder model so the fixture passes the 'models or reaction_systems required' constraint."},
      "variables": {
        "T": {"type": "state", "units": "K", "default": 273.15}
      },
      "equations": [
        {"lhs": "D(T)", "rhs": "0"}
      ]
    }
  },
  "grids": {
    "wrf_lcc": {
      "family": "cartesian",
      "crs": {
        "projection": "lambert_conformal",
        "datum": "sphere",
        "R": 6370000.0,
        "parameters": {"lat_1": 30.0, "lat_2": 60.0, "lat_0": 38.999996, "lon_0": -97.0}
      },
      "description": "WRF native Lambert Conformal Conic grid on a spherical datum. Topologically cartesian; the crs descriptor names the projection and parameters a downstream reprojection rule consumes (the grid performs no reprojection itself).",
      "dimensions": ["x", "y"],
      "extents": {
        "x": {"n": "Nx", "spacing": "uniform"},
        "y": {"n": "Ny", "spacing": "uniform"}
      },
      "locations": ["cell_center", "x_face", "y_face"],
      "parameters": {
        "Nx": {"default": 425},
        "Ny": {"default": 300}
      }
    }
  }
}
