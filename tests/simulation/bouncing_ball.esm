{
  "esm": "0.1.0",
  "metadata": {
    "name": "BouncingBallTest",
    "description": "Ball dropping with elastic collisions - continuous event handling test",
    "authors": [
      "Test Suite"
    ],
    "created": "2026-02-14T00:00:00Z",
    "tags": [
      "test",
      "events",
      "continuous",
      "collision"
    ]
  },
  "models": {
    "BallDynamics": {
      "reference": {
        "notes": "Free falling ball with elastic bounces: h'' = -g, bounce when h = 0"
      },
      "variables": {
        "height": {
          "type": "state",
          "units": "m",
          "default": 10.0,
          "description": "Height above ground"
        },
        "velocity": {
          "type": "state",
          "units": "m/s",
          "default": 0.0,
          "description": "Vertical velocity (positive upward)"
        },
        "g": {
          "type": "parameter",
          "units": "m/s^2",
          "default": 9.81,
          "description": "Gravitational acceleration"
        },
        "restitution": {
          "type": "parameter",
          "units": "1",
          "default": 0.8,
          "description": "Coefficient of restitution"
        }
      },
      "equations": [
        {
          "lhs": {
            "op": "D",
            "args": [
              "height"
            ],
            "wrt": "t"
          },
          "rhs": "velocity"
        },
        {
          "lhs": {
            "op": "D",
            "args": [
              "velocity"
            ],
            "wrt": "t"
          },
          "rhs": {
            "op": "-",
            "args": [
              "g"
            ]
          }
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "height"
            ]
          },
          "rhs": 10.0
        },
        {
          "lhs": {
            "op": "ic",
            "args": [
              "velocity"
            ]
          },
          "rhs": 0.0
        }
      ],
      "continuous_events": [
        {
          "name": "ground_collision",
          "description": "Ball hits ground when height crosses zero from above",
          "conditions": [
            "height"
          ],
          "affects": [
            {
              "lhs": "height",
              "rhs": 0.0
            },
            {
              "lhs": "velocity",
              "rhs": {
                "op": "*",
                "args": [
                  {
                    "op": "-",
                    "args": [
                      "restitution"
                    ]
                  },
                  {
                    "op": "Pre",
                    "args": [
                      "velocity"
                    ]
                  }
                ]
              }
            }
          ],
          "root_find": "left"
        }
      ],
      "tolerance": {
        "abs": 0.02,
        "rel": 0.01
      },
      "tests": [
        {
          "id": "elastic_bounce_sequence",
          "description": "Drop a ball from h=10 m under g=9.81 m/s^2 with restitution=0.8 and check the FIRST bounce against the CLOSED FORM. Free fall gives h(t)=10-g t^2/2, so the ball first reaches the ground at t1=sqrt(2*10/g)=1.427843 s with impact speed sqrt(2*g*10)=14.007141 m/s. The event sets height:=0 and velocity:=-restitution*Pre(velocity)=+11.205713 m/s, after which h(t)=v1*(t-t1)-g*(t-t1)^2/2 with apex h0*e^2=6.4 m -- the h_n=10*e^(2n) decay law, verified analytically rather than sampled. The velocity assertions at t=0.998492 (pre-impact, -9.795204) and t=1.984081 (post-impact, +5.749019) are what actually pin that the event FIRED and applied the restitution: a binding that never builds the callback stays in free fall and misses both. ASSERTIONS STOP AFTER THE FIRST BOUNCE ON PURPOSE. Every value here is exact, but a SOLVER's realized trajectory drifts a little at each zero-crossing re-detection, and because height changes fast near a bounce a small event-time error becomes a large height error one arc later; assertions at the 2nd/3rd/7th bounce were tolerance-dependent, not physics. The previous golden pinned five post-bounce values that were simply WRONG -- 4.882389 at t=1.984081 where the closed form gives 4.715432, and errors up to 2.67 m further out; it also pinned h(10)=0 although the ball does not come to rest until t=t1+2*e*s0/(g*(1-e))=12.850588 s (h(10)=0.321011).",
          "initial_conditions": {
            "height": 10.0,
            "velocity": 0.0
          },
          "parameter_overrides": {
            "g": 9.81,
            "restitution": 0.8
          },
          "time_span": {
            "start": 0.0,
            "end": 10.0
          },
          "assertions": [
            {
              "variable": "height",
              "time": 0.0,
              "expected": 10.0
            },
            {
              "variable": "velocity",
              "time": 0.0,
              "expected": 0.0
            },
            {
              "variable": "height",
              "time": 0.998492,
              "expected": 5.109782,
              "tolerance": {
                "abs": 0.01
              }
            },
            {
              "variable": "velocity",
              "time": 0.998492,
              "expected": -9.795207,
              "tolerance": {
                "abs": 0.02
              }
            },
            {
              "variable": "height",
              "time": 1.984081,
              "expected": 4.715432,
              "tolerance": {
                "abs": 0.01
              }
            },
            {
              "variable": "velocity",
              "time": 1.984081,
              "expected": 5.749019,
              "tolerance": {
                "abs": 0.02
              }
            },
            {
              "variable": "height",
              "time": 2.96743,
              "expected": 5.625711,
              "tolerance": {
                "abs": 0.01
              }
            }
          ]
        }
      ],
      "examples": [
        {
          "id": "default_drop",
          "description": "A single ball dropped from h=10 m and allowed to bounce for 10 s under default gravity and restitution. Plots height and velocity versus time on a shared time axis.",
          "initial_state": {
            "height": 10.0,
            "velocity": 0.0
          },
          "parameters": {
            "g": 9.81,
            "restitution": 0.8
          },
          "time_span": {
            "start": 0.0,
            "end": 10.0
          },
          "plots": [
            {
              "id": "height_vs_time",
              "type": "line",
              "description": "Ball height versus simulation time, illustrating the decaying envelope of successive bounces.",
              "x": {
                "variable": "t",
                "label": "time (s)"
              },
              "y": {
                "variable": "height",
                "label": "height (m)"
              }
            },
            {
              "id": "velocity_vs_time",
              "type": "line",
              "description": "Ball vertical velocity versus time, showing the discontinuous jumps at each elastic collision.",
              "x": {
                "variable": "t",
                "label": "time (s)"
              },
              "y": {
                "variable": "velocity",
                "label": "velocity (m/s)"
              }
            }
          ]
        }
      ]
    }
  },
  "domain": {
    "temporal": {
      "start": "2026-01-01T00:00:00Z",
      "end": "2026-01-01T00:10:00Z"
    }
  }
}
