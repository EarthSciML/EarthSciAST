{
  "esm": "0.8.0",
  "metadata": {
    "name": "per_variable_scheme_literal_args",
    "description": "The sanctioned per-variable selector (esm-spec §9.6.1/§9.6.8): a NON-parameter string in an args position is a literal that matches only that exact bare variable reference. upwind1_D_u has params: [] and the ground pattern {op: D, args: [u], wrt: x}, so it fires only on D(u, x); central_D_any captures every other D(·, x) through its wildcard f. The ground rule out-ranks the generic rule via explicit priority (the engine never infers specificity, §9.6.3) — mixed schemes on one axis: upwind for u, central for v. This mechanism predates `where` constraints; this fixture pins it cross-binding as the per-variable half of match scoping (docs/content/rfcs/match-pattern-scoping-constraints.md §2).",
    "authors": ["match-pattern-scoping-constraints conformance"]
  },
  "index_sets": {
    "x": { "kind": "interval", "size": 16 }
  },
  "models": {
    "m": {
      "variables": {
        "u": { "type": "state", "units": "1", "default": 1.5, "shape": ["x"], "description": "Advected tracer: upwind scheme" },
        "v": { "type": "state", "units": "1", "default": 2.5, "shape": ["x"], "description": "Diffused tracer: central scheme" },
        "upwind_coef": { "type": "parameter", "units": "1", "default": 0.5, "description": "Stand-in upwind stencil coefficient" },
        "central_coef": { "type": "parameter", "units": "1", "default": 0.25, "description": "Stand-in central stencil coefficient" },
        "du": { "type": "observed", "units": "1", "shape": ["x"], "description": "D(u, x): the ground-pattern upwind rule fires",
          "expression": { "op": "D", "args": ["u"], "wrt": "x" }
        },
        "dv": { "type": "observed", "units": "1", "shape": ["x"], "description": "D(v, x): falls through to the generic central rule",
          "expression": { "op": "D", "args": ["v"], "wrt": "x" }
        }
      },
      "equations": [],
      "expression_templates": {
        "upwind1_D_u": {
          "params": [],
          "priority": 10,
          "match": { "op": "D", "args": ["u"], "wrt": "x" },
          "body": { "op": "*", "args": ["upwind_coef", "u"] }
        },
        "central_D_any": {
          "params": ["f"],
          "priority": 0,
          "match": { "op": "D", "args": ["f"], "wrt": "x" },
          "body": { "op": "*", "args": ["central_coef", "f"] }
        }
      }
    }
  }
}
