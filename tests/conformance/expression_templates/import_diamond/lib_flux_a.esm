{
  "esm": "0.8.0",
  "metadata": { "name": "lib_flux_a", "description": "Left diamond path: imports grid_shared unbound, lowers diffuse_a" },
  "expression_template_imports": [ { "ref": "./grid_shared.esm" } ],
  "expression_templates": {
    "diffuse_a": {
      "params": ["f"],
      "match": { "op": "diffuse_a", "args": ["f"] },
      "body": { "op": "*", "args": ["f", { "op": "apply_expression_template", "args": [], "name": "cell_count", "bindings": {} }] }
    }
  }
}
