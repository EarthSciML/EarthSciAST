{
  "esm": "0.8.0",
  "metadata": { "name": "import_rebind_keyed_factors", "description": "Free-name rebinding at an import edge (esm-spec 9.7.7): the ragged_rowsum library's keyed-factor contract (row_count / row_cols / row_w) is rebound to this model's meshA_* arrays, transitively through the ragged index set's offsets/values AND every occurrence in the rule body. Rebinding un-reserves the factor names in the consumer: the local parameter row_count below is unrelated to the library and does not collide" },
  "models": {
    "Sparse": {
      "expression_template_imports": [
        { "ref": "./ragged_rowsum.esm",
          "rebind": { "row_count": "meshA_count", "row_cols": "meshA_cols", "row_w": "meshA_w" } }
      ],
      "variables": {
        "u": { "type": "state", "units": "1", "shape": ["cols"], "description": "column vector being row-summed" },
        "meshA_count": { "type": "observed", "shape": ["rows"], "description": "offsets keyed factor of the rebound nz_of_row set (per-row nonzero count)", "expression": { "op": "const", "args": [], "value": [2, 1, 2] } },
        "meshA_cols": { "type": "observed", "shape": ["rows", "maxnz"], "description": "values keyed factor of the rebound nz_of_row set (column ids, padded to maxnz)", "expression": { "op": "const", "args": [], "value": [[1, 3], [2, 2], [3, 4]] } },
        "meshA_w": { "type": "observed", "shape": ["rows", "maxnz"], "description": "free weight factor of the rule, rebound from row_w", "expression": { "op": "const", "args": [], "value": [[1.5, 2.5], [0.5, 0.5], [1.25, 3.5]] } },
        "row_count": { "type": "parameter", "units": "1", "default": 7.5, "description": "unrelated consumer parameter reusing the library's factor name: rebinding un-reserved it (esm-spec 9.7.7)" },
        "total": { "type": "observed", "shape": ["rows"], "description": "rowsum(u), lowered by the rebound rule instance", "expression": { "op": "rowsum", "args": ["u"] } }
      },
      "equations": [
        { "lhs": { "op": "D", "args": ["u"], "wrt": "t" }, "rhs": { "op": "-", "args": ["u"] } }
      ]
    }
  }
}
