{
  "esm": "0.8.0",
  "index_sets": {
    "cols": {
      "kind": "interval",
      "size": 4
    },
    "maxnz": {
      "kind": "interval",
      "size": 2
    },
    "nz_of_row": {
      "kind": "ragged",
      "of": [
        "rows"
      ],
      "offsets": "meshA_count",
      "values": "meshA_cols"
    },
    "rows": {
      "kind": "interval",
      "size": 3
    }
  },
  "metadata": {
    "description": "Free-name rebinding at an import edge (esm-spec 9.7.7): the ragged_rowsum library's keyed-factor contract (row_count / row_cols / row_w) is rebound to this model's meshA_* arrays, transitively through the ragged index set's offsets/values AND every occurrence in the rule body. Rebinding un-reserves the factor names in the consumer: the local parameter row_count below is unrelated to the library and does not collide",
    "name": "import_rebind_keyed_factors"
  },
  "models": {
    "Sparse": {
      "equations": [
        {
          "lhs": {
            "args": [
              "u"
            ],
            "op": "D",
            "wrt": "t"
          },
          "rhs": {
            "args": [
              "u"
            ],
            "op": "-"
          }
        }
      ],
      "variables": {
        "meshA_cols": {
          "description": "values keyed factor of the rebound nz_of_row set (column ids, padded to maxnz)",
          "expression": {
            "args": [],
            "op": "const",
            "value": [
              [
                1,
                3
              ],
              [
                2,
                2
              ],
              [
                3,
                4
              ]
            ]
          },
          "shape": [
            "rows",
            "maxnz"
          ],
          "type": "observed"
        },
        "meshA_count": {
          "description": "offsets keyed factor of the rebound nz_of_row set (per-row nonzero count)",
          "expression": {
            "args": [],
            "op": "const",
            "value": [
              2,
              1,
              2
            ]
          },
          "shape": [
            "rows"
          ],
          "type": "observed"
        },
        "meshA_w": {
          "description": "free weight factor of the rule, rebound from row_w",
          "expression": {
            "args": [],
            "op": "const",
            "value": [
              [
                1.5,
                2.5
              ],
              [
                0.5,
                0.5
              ],
              [
                1.25,
                3.5
              ]
            ]
          },
          "shape": [
            "rows",
            "maxnz"
          ],
          "type": "observed"
        },
        "row_count": {
          "default": 7.5,
          "description": "unrelated consumer parameter reusing the library's factor name: rebinding un-reserved it (esm-spec 9.7.7)",
          "type": "parameter",
          "units": "1"
        },
        "total": {
          "description": "rowsum(u), lowered by the rebound rule instance",
          "expression": {
            "args": [
              "u",
              "meshA_cols",
              "meshA_w"
            ],
            "expr": {
              "args": [
                {
                  "args": [
                    "meshA_w",
                    "i",
                    "k"
                  ],
                  "op": "index"
                },
                {
                  "args": [
                    "u",
                    {
                      "args": [
                        "meshA_cols",
                        "i",
                        "k"
                      ],
                      "op": "index"
                    }
                  ],
                  "op": "index"
                }
              ],
              "op": "*"
            },
            "op": "aggregate",
            "output_idx": [
              "i"
            ],
            "ranges": {
              "i": {
                "from": "rows"
              },
              "k": {
                "from": "nz_of_row",
                "of": [
                  "i"
                ]
              }
            },
            "semiring": "sum_product"
          },
          "shape": [
            "rows"
          ],
          "type": "observed"
        },
        "u": {
          "description": "column vector being row-summed",
          "shape": [
            "cols"
          ],
          "type": "state",
          "units": "1"
        }
      }
    }
  }
}
