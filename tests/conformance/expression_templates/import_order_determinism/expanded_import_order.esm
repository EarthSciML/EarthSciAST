{
  "esm": "0.8.0",
  "metadata": {
    "description": "Two libraries declare equal-priority rules matching the same node; the winner is pinned by the effective declaration order = import array order (esm-spec 9.7.4): lib_rule_first wins, y = 2*x",
    "name": "import_order_determinism"
  },
  "models": {
    "M": {
      "equations": [
        {
          "lhs": {
            "args": [
              "x"
            ],
            "op": "D",
            "wrt": "t"
          },
          "rhs": {
            "args": [
              "x"
            ],
            "op": "-"
          }
        }
      ],
      "variables": {
        "x": {
          "default": 1.5,
          "type": "state",
          "units": "1"
        },
        "y": {
          "expression": {
            "args": [
              2,
              "x"
            ],
            "op": "*"
          },
          "type": "observed",
          "units": "1"
        }
      }
    }
  }
}
