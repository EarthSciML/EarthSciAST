{
  "esm": "0.8.0",
  "metadata": { "name": "lib_rule_first", "description": "Equal-priority match rule on {op: lowerme}; body multiplies by 2" },
  "expression_templates": {
    "lower_op_first": {
      "params": ["f"],
      "match": { "op": "lowerme", "args": ["f"] },
      "body": { "op": "*", "args": [2, "f"] }
    }
  }
}
