{
  "esm": "0.9.0",
  "metadata": {
    "name": "opacity_priority_shadowing",
    "description": "esm-spec §9.6.4 rule 4 (RFC out-of-line-expression-templates §7.3, §9.2): the SILENT form of the pattern-opacity divergence. A high-priority (10) compound rule matches D(*(U,Q)); a low-priority (0) generic rule matches D(f). The use site hides *(U,Q) inside the target-free reference `flux_prod`, so the compound rule does NOT fire (reference boundary). The generic rule DOES fire, binding the surviving reference WHOLE via the metavariable f — a silent scheme substitution (first-order marker 1 instead of the monotone marker 999).",
    "authors": ["out-of-line-expression-templates conformance"]
  },
  "index_sets": { "x": { "kind": "interval", "size": 4 } },
  "models": {
    "m": {
      "expression_templates": {
        "flux_prod": {
          "params": ["u", "w"],
          "body": { "op": "*", "args": ["u", "w"] }
        },
        "godunov": {
          "params": ["U", "Q"],
          "priority": 10,
          "match": { "op": "D", "args": [{ "op": "*", "args": ["U", "Q"] }], "wrt": "x" },
          "body": { "op": "*", "args": [999, "U"] }
        },
        "generic": {
          "params": ["f"],
          "priority": 0,
          "match": { "op": "D", "args": ["f"], "wrt": "x" },
          "body": { "op": "*", "args": [1, "f"] }
        }
      },
      "variables": {
        "U": { "type": "state", "units": "1", "shape": ["x"], "default": 1.5 },
        "q": { "type": "state", "units": "1", "shape": ["x"], "default": 0.5 },
        "flux": {
          "type": "observed", "units": "1",
          "expression": {
            "op": "D",
            "args": [
              { "op": "apply_expression_template", "args": [], "name": "flux_prod",
                "bindings": { "u": "U", "w": "q" } }
            ],
            "wrt": "x"
          }
        }
      },
      "equations": [
        { "lhs": { "op": "D", "args": ["U"], "wrt": "t" },
          "rhs": { "op": "-", "args": ["U"] } }
      ]
    }
  }
}
