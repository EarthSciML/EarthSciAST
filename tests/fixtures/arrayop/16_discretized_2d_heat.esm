{
  "esm": "0.1.0",
  "metadata": {
    "name": "arrayop_16_discretized_2d_heat",
    "description": "Discretized 2D heat equation on a 3x3 interior grid (Cartesian, uniform, h=0.25) with homogeneous Dirichlet BCs. Stencil coefficient 1/h^2=16. The domain is padded to 5x5: ghost/boundary cells are at row/col indices 1 and 5 (pinned to 0 via separate boundary arrayop equations), and interior physics lives in rows/cols 2-4. All stencil accesses u[i+/-1,j] and u[i,j+/-1] for i,j in [2,4] stay within [1,5] bounds — no ifelse or clamping needed. IC: interior cell (i,j) gets sin((i-1)*pi/4)*sin((j-1)*pi/4). Exact discrete solution: exp(lambda_2D*t)*IC, lambda_2D=2*16*(2*cos(pi/4)-2)=-18.745165204060956. Tests the neighbor-coupled indexed-state path with ghost-cell padding (ess-ing).",
    "authors": [
      "EarthSciSerialization/polecats/gastown.nux",
      "EarthSciSerialization/polecats/gastown.furiosa"
    ],
    "tags": [
      "arrayop",
      "conformance",
      "stencil",
      "2d",
      "pde",
      "neighbor_coupling",
      "ghost_cell_padding"
    ]
  },
  "models": {
    "Heat2D": {
      "tolerance": {
        "rel": 1e-3,
        "abs": 0.0
      },
      "variables": {
        "u": {
          "type": "state",
          "shape": ["i", "j"]
        }
      },
      "equations": [
        {
          "_comment": "Interior 3x3 cells at rows/cols [2,4]: simple stencil, all neighbor accesses within [1,5] — no ifelse or clamping needed.",
          "lhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["u", "i", "j"]}],
              "wrt": "t"
            },
            "ranges": {"i": [2, 4], "j": [2, 4]}
          },
          "rhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "*",
              "args": [
                16,
                {
                  "op": "+",
                  "args": [
                    {"op": "index", "args": ["u", {"op": "-", "args": ["i", 1]}, "j"]},
                    {"op": "index", "args": ["u", {"op": "+", "args": ["i", 1]}, "j"]},
                    {"op": "index", "args": ["u", "i", {"op": "-", "args": ["j", 1]}]},
                    {"op": "index", "args": ["u", "i", {"op": "+", "args": ["j", 1]}]},
                    {"op": "*", "args": [-4, {"op": "index", "args": ["u", "i", "j"]}]}
                  ]
                }
              ]
            },
            "ranges": {"i": [2, 4], "j": [2, 4]}
          }
        },
        {
          "_comment": "Ghost row 1 (top boundary): D(u[1,j])=0 for j in [1,5], Dirichlet BC.",
          "lhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["u", "i", "j"]}],
              "wrt": "t"
            },
            "ranges": {"i": [1, 1], "j": [1, 5]}
          },
          "rhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": 0.0,
            "ranges": {"i": [1, 1], "j": [1, 5]}
          }
        },
        {
          "_comment": "Ghost row 5 (bottom boundary): D(u[5,j])=0 for j in [1,5], Dirichlet BC.",
          "lhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["u", "i", "j"]}],
              "wrt": "t"
            },
            "ranges": {"i": [5, 5], "j": [1, 5]}
          },
          "rhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": 0.0,
            "ranges": {"i": [5, 5], "j": [1, 5]}
          }
        },
        {
          "_comment": "Ghost column 1 (left boundary, interior rows only): D(u[i,1])=0 for i in [2,4], Dirichlet BC.",
          "lhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["u", "i", "j"]}],
              "wrt": "t"
            },
            "ranges": {"i": [2, 4], "j": [1, 1]}
          },
          "rhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": 0.0,
            "ranges": {"i": [2, 4], "j": [1, 1]}
          }
        },
        {
          "_comment": "Ghost column 5 (right boundary, interior rows only): D(u[i,5])=0 for i in [2,4], Dirichlet BC.",
          "lhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": {
              "op": "D",
              "args": [{"op": "index", "args": ["u", "i", "j"]}],
              "wrt": "t"
            },
            "ranges": {"i": [2, 4], "j": [5, 5]}
          },
          "rhs": {
            "op": "arrayop",
            "args": [],
            "output_idx": ["i", "j"],
            "expr": 0.0,
            "ranges": {"i": [2, 4], "j": [5, 5]}
          }
        }
      ],
      "tests": [
        {
          "id": "mode1_decay_t0.05",
          "description": "First-mode sinusoidal IC at interior cells (padded indices 2-4): u[i,j]=sin((i-1)*pi/4)*sin((j-1)*pi/4). Decays as exp(lambda_2D*0.05)*IC. lambda_2D=-18.745165204060956 gives exp(-0.9372583)~=0.391702. Ghost cells (row/col 1 and 5) are initialized to 0. Asserts three representative interior cells in padded coordinates.",
          "initial_conditions": {
            "u[1,1]": 0.0,
            "u[1,2]": 0.0,
            "u[1,3]": 0.0,
            "u[1,4]": 0.0,
            "u[1,5]": 0.0,
            "u[2,1]": 0.0,
            "u[2,2]": 0.5,
            "u[2,3]": 0.7071067811865476,
            "u[2,4]": 0.5,
            "u[2,5]": 0.0,
            "u[3,1]": 0.0,
            "u[3,2]": 0.7071067811865476,
            "u[3,3]": 1.0,
            "u[3,4]": 0.7071067811865476,
            "u[3,5]": 0.0,
            "u[4,1]": 0.0,
            "u[4,2]": 0.5,
            "u[4,3]": 0.7071067811865476,
            "u[4,4]": 0.5,
            "u[4,5]": 0.0,
            "u[5,1]": 0.0,
            "u[5,2]": 0.0,
            "u[5,3]": 0.0,
            "u[5,4]": 0.0,
            "u[5,5]": 0.0
          },
          "time_span": {"start": 0.0, "end": 0.05},
          "assertions": [
            {"variable": "u[3,3]", "time": 0.05, "expected": 0.391702},
            {"variable": "u[2,2]", "time": 0.05, "expected": 0.195851},
            {"variable": "u[3,2]", "time": 0.05, "expected": 0.276975}
          ]
        }
      ]
    }
  }
}
