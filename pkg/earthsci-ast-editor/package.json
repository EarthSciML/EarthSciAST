{
  "name": "@earthsciml/ast-editor",
  "version": "0.1.0",
  "type": "module",
  "description": "Interactive SolidJS editor for EarthSciML Serialization Format expressions",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && npm run build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "build:watch": "vite build --watch",
    "dev": "vite",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:ci": "vitest run",
    "test:e2e": "vitest run tests/editor/",
    "test:e2e:watch": "vitest --watch tests/editor/",
    "test:all": "vitest run src/ && vitest run tests/editor/",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint src",
    "format": "prettier --write src *.json *.js *.ts",
    "format:check": "prettier --check src *.json *.js *.ts"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "earth-science",
    "scientific-modeling",
    "editor",
    "solidjs",
    "typescript",
    "interactive",
    "expressions",
    "mathematical-modeling"
  ],
  "author": "EarthSciML Authors and Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EarthSciML/EarthSciAST.git",
    "directory": "pkg/earthsci-ast-editor"
  },
  "bugs": {
    "url": "https://github.com/EarthSciML/EarthSciAST/issues"
  },
  "homepage": "https://github.com/EarthSciML/EarthSciAST#readme",
  "dependencies": {
    "d3-force": "^3.0.0",
    "solid-element": "^1.9.1",
    "solid-js": "^1.8.0"
  },
  "peerDependencies": {
    "@earthsciml/ast": "^0.8.0",
    "solid-element": "^1.9.1",
    "solid-js": "^1.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/d3-force": "^3.0.0",
    "@types/node": "^20.0.0",
    "@earthsciml/ast": "file:../earthsci-ast-ts",
    "eslint": "^10.6.0",
    "jsdom": "^25.0.0",
    "prettier": "^3.9.4",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.10",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
