      "variables": {
        "u": {
          "type": "state",
          "units": "kg/m^3",
          "shape": [
            "x"
          ],
          "description": "Advected tracer field over the x index set."
        },
        "c": {
          "type": "parameter",
          "units": "m/s",
          "default": 1.0,
          "description": "Constant transport speed (non-negative; the PPM upwind flux assumes flow in +x)."
        },
        "x0": {
          "type": "parameter",
          "units": "m",
          "default": 0,
          "description": "Left domain edge a = 0 (unit interval): the grid's x0 free name (consumer-supplied geometry contract, grids/cartesian_uniform_1d/grid.esm)."
        },
        "dx": {
          "type": "observed",
          "units": "m",
          "expression": {
            "op": "/",
            "args": [
              1,
              "N"
            ]
          },
          "description": "Grid spacing (b - a)/N = 1/N: the grid's dx free name, resolved inside the rewrite rule's expanded body at evaluation. N is the document-scoped metaparameter (re-exported up the import chain), substituted as an integer literal at load (esm-spec 9.7.6), so loader-API rebinding for the convergence sweep keeps dx consistent."
        }
      },
