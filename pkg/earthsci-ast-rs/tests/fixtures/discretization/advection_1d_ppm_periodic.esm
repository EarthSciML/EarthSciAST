          "params": [
            "ql",
            "qr",
            "qi"
          ],
          "description": "CW84 limited right edge qr_lim(ql,qr,qi)",
          "body": {
            "op": "ifelse",
            "args": [
              {
                "op": "<=",
                "args": [
