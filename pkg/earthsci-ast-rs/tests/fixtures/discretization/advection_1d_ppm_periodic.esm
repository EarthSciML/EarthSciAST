      "tests": [
        {
          "id": "mms_transport",
          "description": "Exact solution u(x,t) = sin(2 pi (x - c t)) with c = 1. Derivation: u_t = -2 pi c cos(2 pi (x - c t)) = -c u_x exactly, periodic on [0,1]; no forcing term. References evaluate at the cell centers x_i = x0 + (i - 1/2) dx = 0 + (i - 1/2)/N, spelled inline per esm-spec 6.6.5 (1-based index space; build-time evaluation folds literals and metaparameters only). The t=0 assertion pins the ic wiring (L2_error 0 within 1e-9). The t=0.1 L2_error assertion bounds the PPM transport error (about 5e-4 relative L2 at the default N=64, well under the 0.01 cap, which holds across the convergence sweep). The t=0.1 mean assertion pins EXACT conservation: the semi-discrete PPM flux-difference telescopes on the periodic ring, so mean(u) is preserved to the bit at its analytic value 0 (the discrete sine has zero mean over the full period). Exact per-resolution errors are pinned in tests/conformance/convergence/advection_1d_ppm_periodic/golden/errors.json.",
          "time_span": {
            "start": 0.0,
            "end": 0.1
          },
          "assertions": [
            {
              "variable": "u",
              "time": 0.0,
              "expected": 0.0,
              "tolerance": {
                "abs": 1e-09
              },
              "reduce": "L2_error",
              "reference": {
                "op": "sin",
                "args": [
                  {
                    "op": "*",
                    "args": [
                      6.283185307179586,
                      {
                        "op": "aggregate",
                        "output_idx": [
                          "i"
                        ],
                        "args": [],
                        "ranges": {
                          "i": {
                            "from": "x"
                          }
                        },
                        "expr": {
                          "op": "+",
                          "args": [
                            0,
                            {
                              "op": "*",
                              "args": [
                                {
                                  "op": "-",
                                  "args": [
                                    "i",
                                    0.5
                                  ]
                                },
                                {
                                  "op": "/",
                                  "args": [
                                    1,
                                    "N"
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      }
                    ]
                  }
                ]
              }
            },
            {
              "variable": "u",
              "time": 0.1,
              "expected": 0.0,
              "tolerance": {
                "abs": 0.01
              },
              "reduce": "L2_error",
              "reference": {
