                      {
                        "op": "apply_expression_template",
                        "args": [],
                        "name": "ppm_slope_mono",
                        "bindings": {
                          "am": "b",
                          "a0": "c",
                          "ap": "d"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        },
